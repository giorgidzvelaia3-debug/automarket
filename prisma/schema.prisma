// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENUMS — Core
// ═══════════════════════════════════════════════════════════════════════════════

enum Role {
  ADMIN
  VENDOR
  BUYER
}

enum VendorStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENUMS — Promotions & Finance & Returns
// ═══════════════════════════════════════════════════════════════════════════════

enum FlashSaleStatus {
  ACTIVE
  ENDED
  REJECTED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum SaleMode {
  PRODUCTS
  CATEGORY
}

// ═══════════════════════════════════════════════════════════════════════════════
// USER & AUTH
// ═══════════════════════════════════════════════════════════════════════════════

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  role      Role     @default(BUYER)
  createdAt DateTime @default(now())

  vendor                Vendor?
  cartItems             CartItem[]
  orders                Order[]        @relation("BuyerOrders")
  reviews               Review[]
  buyerConversations    Conversation[] @relation("BuyerConversations")
  sentMessages          Message[]
  wishlistItems         Wishlist[]
  returnRequests        ReturnRequest[]
}

// ═══════════════════════════════════════════════════════════════════════════════
// VENDOR & PRODUCTS
// ═══════════════════════════════════════════════════════════════════════════════

model Vendor {
  id              String       @id @default(cuid())
  userId          String       @unique
  name            String
  slug            String       @unique
  description     String?
  logo            String?
  phone           String?
  status          VendorStatus @default(PENDING)
  vacationMode    Boolean      @default(false)
  vacationMessage String?
  vacationEnd     DateTime?
  minOrderAmount  Decimal?     @db.Decimal(10, 2)
  maxOrderAmount  Decimal?     @db.Decimal(10, 2)
  minOrderQty     Int?
  maxOrderQty     Int?
  createdAt       DateTime     @default(now())

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  products       Product[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  conversations  Conversation[]     @relation("VendorConversations")
  flashSales     FlashSale[]
  withdrawals    VendorWithdrawal[]
  coupons        Coupon[]
  badges         VendorBadge[]
  returnRequests ReturnRequest[]
}

model Category {
  id       String  @id @default(cuid())
  name     String
  nameEn   String
  slug     String  @unique
  icon     String?
  parentId String?

  parent     Category?    @relation("CategoryChildren", fields: [parentId], references: [id])
  children   Category[]   @relation("CategoryChildren")
  products   Product[]
  flashSales FlashSale[]
  coupons    Coupon[]
}

model Product {
  id            String        @id @default(cuid())
  vendorId      String
  categoryId    String
  name          String
  nameEn        String
  slug          String        @unique
  description   String?
  descriptionEn String?
  price         Decimal       @db.Decimal(10, 2)
  stock         Int           @default(0)
  status        ProductStatus @default(DRAFT)
  createdAt     DateTime      @default(now())

  vendor     Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category   Category       @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  variants      ProductVariant[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  reviews        Review[]
  conversations  Conversation[]
  wishlistItems  Wishlist[]
  flashSaleItems FlashSaleItem[]
  coupons        Coupon[]

  @@index([vendorId])
  @@index([status, categoryId, createdAt])
  @@index([status, vendorId, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════════
// ORDERS & CART
// ═══════════════════════════════════════════════════════════════════════════════

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  vendorId  String
  variantId String?
  quantity  Int      @default(1)
  price     Decimal? @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor  Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([userId, productId, variantId])
  @@index([userId])
}

model Order {
  id             String      @id @default(cuid())
  buyerId        String?
  guestName      String?
  guestEmail     String?
  guestPhone     String?
  status         OrderStatus @default(PENDING)
  total          Decimal     @db.Decimal(10, 2)
  couponCode     String?
  couponDiscount Decimal?    @db.Decimal(10, 2)
  address        String?
  note           String?
  createdAt      DateTime    @default(now())

  buyer          User?           @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]
  couponUses     CouponUse[]
  returnRequests ReturnRequest[]

  @@index([buyerId, createdAt])
  @@index([status])
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  productId       String
  vendorId        String
  variantId       String?
  variantName     String?
  quantity        Int
  price           Decimal @db.Decimal(10, 2)
  vendorEarning   Decimal @db.Decimal(10, 2) @default(0)
  adminCommission Decimal @db.Decimal(10, 2) @default(0)
  commissionRate  Decimal @db.Decimal(5, 2)  @default(0)

  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  vendor      Vendor          @relation(fields: [vendorId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  returnItems ReturnItem[]

  @@index([orderId])
  @@index([vendorId])
}

model ProductImage {
  id        String @id @default(cuid())
  productId String
  url       String
  order     Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId, createdAt])
}

model Conversation {
  id        String   @id @default(cuid())
  buyerId   String
  vendorId  String
  productId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer    User      @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  vendor   Vendor    @relation("VendorConversations", fields: [vendorId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  messages Message[]

  @@unique([buyerId, vendorId, productId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  name      String
  nameEn    String
  price     Decimal @db.Decimal(10, 2)
  stock     Int     @default(0)
  sku       String?
  order     Int     @default(0)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PROMOTIONS (Flash Sales, Coupons)
// ═══════════════════════════════════════════════════════════════════════════════

model FlashSale {
  id                   String           @id @default(cuid())
  vendorId             String
  title                String
  titleEn              String
  startTime            DateTime
  endTime              DateTime
  status               FlashSaleStatus  @default(ACTIVE)
  featured             Boolean          @default(false)
  saleMode             SaleMode         @default(PRODUCTS)
  categoryId           String?
  categoryDiscount     Decimal?         @db.Decimal(10, 2)
  categoryDiscountType DiscountType?
  createdAt            DateTime         @default(now())

  vendor   Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  items    FlashSaleItem[]

  @@index([vendorId])
  @@index([status, startTime, endTime])
}

model FlashSaleItem {
  id            String       @id @default(cuid())
  flashSaleId   String
  productId     String
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  salePrice     Decimal      @db.Decimal(10, 2)
  originalPrice Decimal      @db.Decimal(10, 2)
  maxQuantity   Int?
  soldCount     Int          @default(0)

  flashSale FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@index([productId])
}

enum CommissionType {
  GLOBAL
  VENDOR
  CATEGORY
  PRODUCT
}

enum WithdrawalMethod {
  BANK_TRANSFER
  PAYPAL
  CASH
  OTHER
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// ═══════════════════════════════════════════════════════════════════════════════
// FINANCE (Commission, Withdrawals)
// ═══════════════════════════════════════════════════════════════════════════════

model CommissionSetting {
  id          String         @id @default(cuid())
  type        CommissionType
  referenceId String?
  percentage  Decimal        @db.Decimal(5, 2)
  updatedAt   DateTime       @updatedAt

  @@unique([type, referenceId])
}

model VendorWithdrawal {
  id          String           @id @default(cuid())
  vendorId    String
  amount      Decimal          @db.Decimal(10, 2)
  method      WithdrawalMethod
  status      WithdrawalStatus @default(PENDING)
  note        String?
  adminNote   String?
  requestedAt DateTime         @default(now())
  processedAt DateTime?

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, status])
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum CouponScope {
  MARKETPLACE
  VENDOR
  PRODUCT
  CATEGORY
}

enum CouponCreator {
  ADMIN
  VENDOR
}

enum BadgeType {
  VERIFIED
  TOP_SELLER
  HIGH_RATED
  TRUSTED
  NEW_VENDOR
}

model Coupon {
  id             String        @id @default(cuid())
  code           String        @unique
  type           CouponType
  value          Decimal       @db.Decimal(10, 2)
  scope          CouponScope
  vendorId       String?
  categoryId     String?
  productId      String?
  minOrderAmount Decimal?      @db.Decimal(10, 2)
  maxUses        Int?
  usedCount      Int           @default(0)
  startDate      DateTime?
  endDate        DateTime?
  isActive       Boolean       @default(true)
  createdBy      CouponCreator
  createdById    String
  createdAt      DateTime      @default(now())

  vendor   Vendor?     @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  category Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  product  Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  uses     CouponUse[]

  @@index([vendorId, createdAt])
}

model CouponUse {
  id       String   @id @default(cuid())
  couponId String
  orderId  String
  userId   String?
  discount Decimal  @db.Decimal(10, 2)
  usedAt   DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model VendorBadge {
  id        String    @id @default(cuid())
  vendorId  String
  badge     BadgeType
  awardedAt DateTime  @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, badge])
}

enum ReturnReason {
  DEFECTIVE
  WRONG_ITEM
  NOT_AS_DESCRIBED
  CHANGED_MIND
  OTHER
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum ReturnType {
  RETURN
  WARRANTY
}

// ═══════════════════════════════════════════════════════════════════════════════
// RETURNS & WARRANTY
// ═══════════════════════════════════════════════════════════════════════════════

model ReturnRequest {
  id          String       @id @default(cuid())
  orderId     String
  buyerId     String
  vendorId    String
  reason      ReturnReason
  description String?
  images      String[]
  status      ReturnStatus @default(PENDING)
  type        ReturnType
  vendorNote  String?
  adminNote   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  order  Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyer  User         @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  vendor Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  items  ReturnItem[]

  @@index([vendorId, status])
  @@index([buyerId])
}

model ReturnItem {
  id              String @id @default(cuid())
  returnRequestId String
  orderItemId     String
  quantity        Int

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem     OrderItem     @relation(fields: [orderItemId], references: [id])
}
