// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENUMS — Core
// ═══════════════════════════════════════════════════════════════════════════════

enum Role {
  ADMIN
  VENDOR
  BUYER
}

enum VendorStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENUMS — Promotions & Finance & Returns
// ═══════════════════════════════════════════════════════════════════════════════

enum FlashSaleStatus {
  ACTIVE
  ENDED
  REJECTED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum SaleMode {
  PRODUCTS
  CATEGORY
}

// ═══════════════════════════════════════════════════════════════════════════════
// USER & AUTH
// ═══════════════════════════════════════════════════════════════════════════════

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  role      Role     @default(BUYER)
  createdAt DateTime @default(now())

  vendor                Vendor?
  cartItems             CartItem[]
  orders                Order[]        @relation("BuyerOrders")
  reviews               Review[]
  buyerConversations    Conversation[] @relation("BuyerConversations")
  sentMessages          Message[]
  wishlistItems         Wishlist[]
  returnRequests        ReturnRequest[]
}

// ═══════════════════════════════════════════════════════════════════════════════
// VENDOR & PRODUCTS
// ═══════════════════════════════════════════════════════════════════════════════

model Vendor {
  id              String       @id @default(cuid())
  userId          String       @unique
  name            String
  slug            String       @unique
  description     String?
  logo            String?
  phone           String?
  status          VendorStatus @default(PENDING)
  vacationMode    Boolean      @default(false)
  vacationMessage String?
  vacationEnd     DateTime?
  minOrderAmount  Decimal?     @db.Decimal(10, 2)
  maxOrderAmount  Decimal?     @db.Decimal(10, 2)
  minOrderQty     Int?
  maxOrderQty     Int?
  createdAt       DateTime     @default(now())

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  products       Product[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  conversations  Conversation[]     @relation("VendorConversations")
  flashSales     FlashSale[]
  withdrawals    VendorWithdrawal[]
  coupons        Coupon[]
  badges         VendorBadge[]
  returnRequests ReturnRequest[]
}

model Category {
  id       String  @id @default(cuid())
  name     String
  nameEn   String
  slug     String  @unique
  icon     String?
  parentId String?

  parent     Category?    @relation("CategoryChildren", fields: [parentId], references: [id])
  children   Category[]   @relation("CategoryChildren")
  products   Product[]
  flashSales FlashSale[]
  coupons    Coupon[]
  aggregatedProducts AggregatedProduct[]

  @@index([parentId])
}

model Product {
  id            String        @id @default(cuid())
  vendorId      String
  categoryId    String
  name          String
  nameEn        String
  slug          String        @unique
  description   String?
  descriptionEn String?
  price         Decimal       @db.Decimal(10, 2)
  stock         Int           @default(0)
  status        ProductStatus @default(DRAFT)
  createdAt     DateTime      @default(now())

  vendor     Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category   Category       @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  variants      ProductVariant[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  reviews        Review[]
  conversations  Conversation[]
  wishlistItems  Wishlist[]
  flashSaleItems FlashSaleItem[]
  coupons        Coupon[]
  bundlesOwned   ProductBundle[] @relation("BundleOwner")
  bundledIn      ProductBundle[] @relation("BundleItem")

  @@index([vendorId])
  @@index([status, categoryId, createdAt])
  @@index([status, vendorId, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════════
// ORDERS & CART
// ═══════════════════════════════════════════════════════════════════════════════

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  vendorId  String
  variantId String?
  quantity  Int      @default(1)
  price     Decimal? @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor  Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([userId, productId, variantId])
  @@index([userId])
}

model Order {
  id             String      @id @default(cuid())
  buyerId        String?
  guestName      String?
  guestEmail     String?
  guestPhone     String?
  status         OrderStatus @default(PENDING)
  total          Decimal     @db.Decimal(10, 2)
  couponCode     String?
  couponDiscount Decimal?    @db.Decimal(10, 2)
  address        String?
  note           String?
  createdAt      DateTime    @default(now())

  buyer          User?           @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]
  couponUses     CouponUse[]
  returnRequests ReturnRequest[]

  @@index([buyerId, createdAt])
  @@index([status])
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  productId       String
  vendorId        String
  variantId       String?
  variantName     String?
  quantity        Int
  price           Decimal @db.Decimal(10, 2)
  vendorEarning   Decimal @db.Decimal(10, 2) @default(0)
  adminCommission Decimal @db.Decimal(10, 2) @default(0)
  commissionRate  Decimal @db.Decimal(5, 2)  @default(0)

  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  vendor      Vendor          @relation(fields: [vendorId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  returnItems ReturnItem[]

  @@index([orderId])
  @@index([vendorId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  variantId String?
  url       String
  order     Int     @default(0)

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([variantId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId, createdAt])
}

model Conversation {
  id        String   @id @default(cuid())
  buyerId   String
  vendorId  String
  productId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer    User      @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  vendor   Vendor    @relation("VendorConversations", fields: [vendorId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  messages Message[]

  @@unique([buyerId, vendorId, productId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  name      String
  nameEn    String
  price     Decimal @db.Decimal(10, 2)
  stock     Int     @default(0)
  sku       String?
  order     Int     @default(0)

  product    Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]
  images     ProductImage[]

  @@index([productId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PROMOTIONS (Flash Sales, Coupons)
// ═══════════════════════════════════════════════════════════════════════════════

model FlashSale {
  id                   String           @id @default(cuid())
  vendorId             String
  title                String
  titleEn              String
  startTime            DateTime
  endTime              DateTime
  status               FlashSaleStatus  @default(ACTIVE)
  featured             Boolean          @default(false)
  saleMode             SaleMode         @default(PRODUCTS)
  categoryId           String?
  categoryDiscount     Decimal?         @db.Decimal(10, 2)
  categoryDiscountType DiscountType?
  createdAt            DateTime         @default(now())

  vendor   Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  items    FlashSaleItem[]

  @@index([vendorId])
  @@index([status, startTime, endTime])
}

model FlashSaleItem {
  id            String       @id @default(cuid())
  flashSaleId   String
  productId     String
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  salePrice     Decimal      @db.Decimal(10, 2)
  originalPrice Decimal      @db.Decimal(10, 2)
  maxQuantity   Int?
  soldCount     Int          @default(0)

  flashSale FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([flashSaleId])
}

enum CommissionType {
  GLOBAL
  VENDOR
  CATEGORY
  PRODUCT
}

enum WithdrawalMethod {
  BANK_TRANSFER
  PAYPAL
  CASH
  OTHER
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// ═══════════════════════════════════════════════════════════════════════════════
// FINANCE (Commission, Withdrawals)
// ═══════════════════════════════════════════════════════════════════════════════

model CommissionSetting {
  id          String         @id @default(cuid())
  type        CommissionType
  referenceId String?
  percentage  Decimal        @db.Decimal(5, 2)
  updatedAt   DateTime       @updatedAt

  @@unique([type, referenceId])
}

model VendorWithdrawal {
  id          String           @id @default(cuid())
  vendorId    String
  amount      Decimal          @db.Decimal(10, 2)
  method      WithdrawalMethod
  status      WithdrawalStatus @default(PENDING)
  note        String?
  adminNote   String?
  requestedAt DateTime         @default(now())
  processedAt DateTime?

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, status])
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum CouponScope {
  MARKETPLACE
  VENDOR
  PRODUCT
  CATEGORY
}

enum CouponCreator {
  ADMIN
  VENDOR
}

enum BadgeType {
  VERIFIED
  TOP_SELLER
  HIGH_RATED
  TRUSTED
  NEW_VENDOR
}

model Coupon {
  id             String        @id @default(cuid())
  code           String        @unique
  type           CouponType
  value          Decimal       @db.Decimal(10, 2)
  scope          CouponScope
  vendorId       String?
  categoryId     String?
  productId      String?
  minOrderAmount Decimal?      @db.Decimal(10, 2)
  maxUses        Int?
  usedCount      Int           @default(0)
  startDate      DateTime?
  endDate        DateTime?
  isActive       Boolean       @default(true)
  createdBy      CouponCreator
  createdById    String
  createdAt      DateTime      @default(now())

  vendor   Vendor?     @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  category Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  product  Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  uses     CouponUse[]

  @@index([vendorId, createdAt])
  @@index([createdById])
}

model CouponUse {
  id       String   @id @default(cuid())
  couponId String
  orderId  String
  userId   String?
  discount Decimal  @db.Decimal(10, 2)
  usedAt   DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model VendorBadge {
  id        String    @id @default(cuid())
  vendorId  String
  badge     BadgeType
  awardedAt DateTime  @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, badge])
}

enum ReturnReason {
  DEFECTIVE
  WRONG_ITEM
  NOT_AS_DESCRIBED
  CHANGED_MIND
  OTHER
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum ReturnType {
  RETURN
  WARRANTY
}

// ═══════════════════════════════════════════════════════════════════════════════
// RETURNS & WARRANTY
// ═══════════════════════════════════════════════════════════════════════════════

model ReturnRequest {
  id          String       @id @default(cuid())
  orderId     String
  buyerId     String
  vendorId    String
  reason      ReturnReason
  description String?
  images      String[]
  status      ReturnStatus @default(PENDING)
  type        ReturnType
  vendorNote  String?
  adminNote   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  order  Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyer  User         @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  vendor Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  items  ReturnItem[]

  @@index([vendorId, status])
  @@index([buyerId])
}

model ReturnItem {
  id              String @id @default(cuid())
  returnRequestId String
  orderItemId     String
  quantity        Int

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem     OrderItem     @relation(fields: [orderItemId], references: [id])
}

// ═══════════════════════════════════════════════════════════════════════════════
// BANNERS
// ═══════════════════════════════════════════════════════════════════════════════

model Banner {
  id        String   @id @default(cuid())
  title     String
  titleEn   String?
  subtitle  String?
  subtitleEn String?
  imageUrl  String
  linkUrl   String?
  position  BannerPosition @default(HERO)
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BannerPosition {
  HERO
  SIDE_TOP
  SIDE_BOTTOM
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRODUCT BUNDLES ("ერთად იაფია")
// ═══════════════════════════════════════════════════════════════════════════════

model ProductBundle {
  id              String @id @default(cuid())
  productId       String
  bundleProductId String
  discountPercent Int    @default(5)
  order           Int    @default(0)

  product       Product @relation("BundleOwner", fields: [productId], references: [id], onDelete: Cascade)
  bundleProduct Product @relation("BundleItem", fields: [bundleProductId], references: [id], onDelete: Cascade)

  @@unique([productId, bundleProductId])
  @@index([productId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// AGGREGATED PRODUCTS (price comparison — scraped from external retailers)
// These are NOT orderable through the site. Each canonical AggregatedProduct
// groups one or more ProductOffers (one per source) and the product page shows
// a price-comparison table that links out to each source's product page.
// ═══════════════════════════════════════════════════════════════════════════════

enum SourceKind {
  STATIC_HTML // server-rendered HTML — fetch + cheerio (e.g. amboli.ge)
  JS_RENDERED // client-rendered — internal JSON API or headless (e.g. otomotors.shop)
}

enum SyncRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum MatchProposalStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum OfferAvailability {
  IN_STOCK
  OUT_OF_STOCK
  UNKNOWN
}

model Source {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  baseUrl      String
  kind         SourceKind @default(STATIC_HTML)
  logo         String?
  enabled      Boolean    @default(true)
  config       Json? // { categoryUrls: string[], pagesMax?: number, apiEndpoint?: string, ... }
  lastSyncedAt DateTime?
  createdAt    DateTime   @default(now())

  offers   ProductOffer[]
  syncRuns SyncRun[]
}

model AggregatedProduct {
  id            String        @id @default(cuid())
  categoryId    String
  name          String
  nameEn        String
  slug          String        @unique
  description   String?
  descriptionEn String?
  imageUrl      String? // hotlinked source URL — never re-uploaded
  brand         String?
  viscosity     String?
  volume        String?
  matchKey      String?
  status        ProductStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  category       Category        @relation(fields: [categoryId], references: [id])
  offers         ProductOffer[]
  matchProposals MatchProposal[]

  @@index([status, categoryId, createdAt])
  @@index([matchKey])
}

model ProductOffer {
  id                  String            @id @default(cuid())
  sourceId            String
  aggregatedProductId String? // null until an admin confirms a match
  rawName             String
  sourceUrl           String // outbound product page link (also the upsert key)
  sourceImageUrl      String? // hotlinked source URL — never re-uploaded
  price               Decimal           @db.Decimal(10, 2)
  originalPrice       Decimal?          @db.Decimal(10, 2)
  discountPercent     Int?
  availability        OfferAvailability @default(UNKNOWN)
  brand               String?
  viscosity           String?
  volume              String?
  matchKey            String?
  specs               Json? // key/value characteristics scraped from the product page
  lastCheckedAt       DateTime          @default(now())
  firstSeenAt         DateTime          @default(now())
  missingSince        DateTime? // set when a sync no longer finds it
  active              Boolean           @default(true)
  createdAt           DateTime          @default(now())

  source            Source             @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  aggregatedProduct AggregatedProduct? @relation(fields: [aggregatedProductId], references: [id], onDelete: SetNull)
  matchProposals    MatchProposal[]

  @@unique([sourceId, sourceUrl])
  @@index([aggregatedProductId])
  @@index([matchKey])
  @@index([sourceId, active])
}

model MatchProposal {
  id                  String              @id @default(cuid())
  offerId             String
  aggregatedProductId String? // merge into existing canonical...
  proposedName        String? // ...or create a new canonical from this offer
  proposedNameEn      String?
  confidence          Int // 0–100 heuristic score
  matchKey            String
  status              MatchProposalStatus @default(PENDING)
  createdAt           DateTime            @default(now())
  resolvedAt          DateTime?

  offer             ProductOffer       @relation(fields: [offerId], references: [id], onDelete: Cascade)
  aggregatedProduct AggregatedProduct? @relation(fields: [aggregatedProductId], references: [id], onDelete: Cascade)

  @@index([status, confidence])
  @@index([offerId])
}

model SyncRun {
  id               String        @id @default(cuid())
  sourceId         String
  status           SyncRunStatus @default(RUNNING)
  startedAt        DateTime      @default(now())
  finishedAt       DateTime?
  offersSeen       Int           @default(0)
  offersUpdated    Int           @default(0)
  offersNew        Int           @default(0)
  offersMissing    Int           @default(0)
  proposalsCreated Int           @default(0)
  error            String?
  log              Json?

  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, startedAt])
}
